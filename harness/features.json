    ],
    "run_tests": false,
    "pre_eval_command": "node -e \"const fs=require('fs'),dns=require('dns');const md=fs.readFileSync('docs/api-discovery.md','utf8');const m=md.match(/https?:\\/\\/[^\\s\\)>\\`'\\\"\\\\[\\\\]]+/);if(!m){console.error('VALIDATION FAIL: no URL found in docs/api-discovery.md');process.exit(1);}let u;try{u=new URL(m[0]);}catch(e){console.error('VALIDATION FAIL: invalid URL: '+m[0]);process.exit(1);}dns.resolve(u.hostname,function(err){if(err){console.error('VALIDATION FAIL: host does not resolve: '+u.hostname+' \u2014 '+err.message);process.exit(1);}else{console.log('PASS: URL valid, host resolves: '+u.hostname);process.exit(0);}});\""
  },
