    "run_tests": false,
    "pre_eval_command": "node -e \"const fs=require('fs');let raw;try{raw=fs.readFileSync('data/latest.json','utf8');}catch(e){console.error('VALIDATION FAIL: data/latest.json unreadable: '+e.message);process.exit(1);}let d;try{d=JSON.parse(raw);}catch(e){console.error('VALIDATION FAIL: not valid JSON: '+e.message);process.exit(1);}const errs=[];if(typeof d.fetched_at!=='string'||!d.fetched_at)errs.push('fetched_at missing or not a non-empty string');if(typeof d.count!=='number')errs.push('count missing or not a number');if(!Array.isArray(d.signs))errs.push('signs missing or not an array');else{if(d.signs.length===0)errs.push('signs array is empty \u2014 real fetched data required');if(typeof d.count==='number'&&d.count!==d.signs.length)errs.push('count ('+d.count+') does not match signs.length ('+d.signs.length+')');if(d.signs.length>0&&Object.keys(d.signs[0]).length<4)errs.push('signs[0] has fewer than 4 keys \u2014 appears to be a placeholder object');}if(errs.length>0){console.error('VALIDATION FAIL:\\n'+errs.map(function(e){return'  - '+e;}).join('\\n'));process.exit(1);}console.log('PASS: '+d.signs.length+' signs, fetched_at='+d.fetched_at);process.exit(0);\""
  },
